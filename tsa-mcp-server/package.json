{
  "name": "specter-tree",
  "version": "0.1.0",
  "description": "MCP server for TypeScript codebases. Reduces Claude Code token usage 54–67%. AI agents find symbols by name — no full-file reads.",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "ast",
    "claude-code",
    "cursor",
    "codex",
    "token-optimization",
    "ai-agent",
    "code-navigation",
    "symbol-search",
    "llm-tools",
    "codebase-intelligence",
    "reduce-tokens",
    "bun"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@ts-morph/common": "0.28.1",
    "chalk": "^5.6.2",
    "chokidar": "5.0.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "ts-morph": "27.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "bun-types": "1.3.11",
    "husky": "9.1.7",
    "typescript": "6.0.2"
  }
}
